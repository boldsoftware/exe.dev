# /etc/default/exe-ops-server
# Environment variables for exe-ops-server

# Required: authentication token for agent connections
EXE_OPS_TOKEN=

# Listen address (default: tailscale:443 when deployed via ops/deploy-exe-ops-server.sh)
#EXE_OPS_ADDR=tailscale:443

# SQLite database path (default: exe-ops.db)
#EXE_OPS_DB=/opt/exe-ops/exe-ops.db

# Data retention duration (default: 168h = 7 days)
#EXE_OPS_RETENTION=168h

# Slack bot token for deploy notifications (posts to #ship for prod, #boat for staging)
#EXE_SLACK_BOT_TOKEN=
