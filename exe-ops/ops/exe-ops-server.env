# /etc/default/exe-ops-server
# Environment variables for exe-ops-server

# The deploy script owns EXE_OPS_ENVIRONMENT, EXE_OPS_ADDR, and EXE_OPS_TLS
# via /etc/systemd/system/exe-ops-server.service.d/environment.conf.
#EXE_OPS_ADDR=tailscale:443

# Bare git clone path and source repo.
#EXE_OPS_GIT_REPO_DIR=/opt/exe-ops/exe-repo.git
#EXE_OPS_GIT_REPO_URL=git@github.com:boldsoftware/exe.git

# Slack bot token for deploy notifications and CD topic updates.
#EXE_SLACK_BOT_TOKEN=
