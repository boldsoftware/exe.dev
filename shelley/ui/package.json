{
  "name": "shelley-ui",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "esbuild src/main.tsx --bundle --outfile=dist/main.js --servedir=dist --watch",
    "build": "mkdir -p dist && cp src/index.html dist/ && cp src/styles.css dist/ && esbuild src/main.tsx --bundle --outfile=dist/main.js --minify --sourcemap",
    "clean": "rm -rf dist/*",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "type-check": "tsc --noEmit",
    "generate-types": "cd .. && go run ./cmd/go2ts.go -o ui/src/generated-types.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:e2e:ui": "npm run build && playwright test --ui",
    "test:e2e:debug": "npm run build && playwright test --debug"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@playwright/test": "^1.40.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^8.43.0",
    "@typescript-eslint/parser": "^8.43.0",
    "esbuild": "^0.19.0",
    "eslint": "^9.35.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.43.0"
  }
}
