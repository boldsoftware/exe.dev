#!/usr/bin/env python3
"""
Generate an SSH config file for all exe.dev VMs.

For each SSH key, runs `ssh -i <key> exe.dev ls --json` to discover VMs,
then writes ~/.ssh/exe-dev-config with Host entries so that
`ssh <vm_name>` connects to <vm_name>.exe.xyz with the correct key.

Usage:
    exe-ssh-config-generator [key1 key2 ...]

If no keys are specified, uses the default keys:
    ~/.ssh/id_ed25519, ~/.ssh/id_ed25519-two, ~/.ssh/id_rsa
(only those that exist on disk).
"""

import json
import os
import subprocess
import sys

CONFIG_FILE = os.path.expanduser("~/.ssh/exe-dev-config")
KNOWN_HOSTS_FILE = os.path.expanduser("~/.ssh/exe-dev-known-hosts")
SSH_CONFIG = os.path.expanduser("~/.ssh/config")
INCLUDE_LINE = "Include ~/.ssh/exe-dev-config"

DEFAULT_KEYS = [
    "~/.ssh/id_ed25519",
    "~/.ssh/id_ed25519-two",
    "~/.ssh/id_rsa",
]


def expand_key(path):
    return os.path.expanduser(path)


def discover_vms(key_path):
    """Run ssh -i <key> exe.dev ls --json and return list of VM dicts."""
    try:
        result = subprocess.run(
            [
                "ssh",
                "-i", key_path,
                "-F", "/dev/null",
                "-o", "IdentityAgent=none",
                "-o", "IdentitiesOnly=yes",
                "-o", "PreferredAuthentications=publickey",
                "-o", "PubkeyAuthentication=yes",
                "-o", "PasswordAuthentication=no",
                "-o", "KbdInteractiveAuthentication=no",
                "-o", "ChallengeResponseAuthentication=no",
                "-o", "StrictHostKeyChecking=no",
                "-o", "UserKnownHostsFile=/dev/null",
                "-o", "GlobalKnownHostsFile=/dev/null",
                "-o", "BatchMode=yes",
                "-o", "LogLevel=ERROR",
                "exe.dev", "ls", "--json",
            ],
            capture_output=True,
            text=True,
            timeout=30,
        )
    except subprocess.TimeoutExpired:
        print(f"  timeout connecting with {key_path}", file=sys.stderr)
        return []

    if result.returncode != 0:
        print(f"  ssh failed with {key_path}: {result.stderr.strip()}", file=sys.stderr)
        return []

    try:
        data = json.loads(result.stdout)
    except json.JSONDecodeError:
        print(f"  invalid JSON from {key_path}", file=sys.stderr)
        return []

    return data.get("vms", [])


def fetch_host_key():
    """Fetch the SSH host key from exe.dev (shared by all VMs via SSHPiper)."""
    try:
        result = subprocess.run(
            ["ssh-keyscan", "exe.dev"],
            capture_output=True,
            text=True,
            timeout=10,
        )
    except subprocess.TimeoutExpired:
        print("  timeout fetching host key from exe.dev", file=sys.stderr)
        return None

    for line in result.stdout.splitlines():
        if line and not line.startswith("#"):
            # Return just the key type and key data (strip the hostname)
            parts = line.split(None, 2)
            if len(parts) == 3:
                return parts[1], parts[2]  # key_type, key_data
    print("  no host key found from exe.dev", file=sys.stderr)
    return None


def write_known_hosts(vm_key_map, host_key):
    """Write a known_hosts file with the exe.dev host key for every VM."""
    key_type, key_data = host_key
    lines = [
        "# Auto-generated by exe-ssh-config-generator",
        "# All exe.dev VMs share the same host key (SSHPiper proxy).",
        "",
    ]
    # Also include exe.dev itself
    lines.append(f"exe.dev {key_type} {key_data}")
    for vm_name in sorted(vm_key_map):
        ssh_dest, _ = vm_key_map[vm_name]
        lines.append(f"{ssh_dest} {key_type} {key_data}")

    with open(KNOWN_HOSTS_FILE, "w") as f:
        f.write("\n".join(lines) + "\n")
    # +1 for exe.dev itself
    print(f"wrote {len(vm_key_map) + 1} entries to {KNOWN_HOSTS_FILE}")


def generate_config(vm_key_map, have_known_hosts):
    """Generate SSH config content for all VMs."""
    lines = [
        "# Auto-generated by exe-ssh-config-generator",
        "# Do not edit manually; re-run the generator to update.",
        "",
    ]

    for vm_name in sorted(vm_key_map):
        ssh_dest, key_path = vm_key_map[vm_name]
        lines.append(f"Host {vm_name} {ssh_dest}")
        lines.append(f"    HostName {ssh_dest}")
        lines.append(f"    IdentityFile {key_path}")
        lines.append(f"    IdentitiesOnly yes")
        lines.append(f"    IdentityAgent none")
        lines.append(f"    PreferredAuthentications publickey")
        lines.append(f"    PubkeyAuthentication yes")
        lines.append(f"    PasswordAuthentication no")
        lines.append(f"    KbdInteractiveAuthentication no")
        if have_known_hosts:
            lines.append(f"    UserKnownHostsFile {KNOWN_HOSTS_FILE}")
            lines.append(f"    StrictHostKeyChecking yes")
        lines.append("")

    return "\n".join(lines)


def ensure_include():
    """Ensure ~/.ssh/config includes our generated config file."""
    if not os.path.exists(SSH_CONFIG):
        with open(SSH_CONFIG, "w") as f:
            f.write(INCLUDE_LINE + "\n\n")
        print(f"  created {SSH_CONFIG} with include")
        return

    with open(SSH_CONFIG, "r") as f:
        content = f.read()

    if INCLUDE_LINE in content:
        return

    # Prepend the include so it takes priority
    with open(SSH_CONFIG, "w") as f:
        f.write(INCLUDE_LINE + "\n" + content)
    print(f"  added include to {SSH_CONFIG}")


def main():
    if len(sys.argv) > 1:
        keys = sys.argv[1:]
    else:
        keys = [expand_key(k) for k in DEFAULT_KEYS if os.path.exists(expand_key(k))]

    if not keys:
        print("error: no SSH keys found or specified", file=sys.stderr)
        sys.exit(1)

    print(f"using keys: {', '.join(keys)}")

    # vm_name -> (ssh_dest, key_path)
    # First key to claim a VM wins.
    vm_key_map = {}

    for key in keys:
        print(f"querying exe.dev with {key} ...")
        vms = discover_vms(key)
        new = 0
        for vm in vms:
            name = vm.get("vm_name")
            dest = vm.get("ssh_dest")
            if name and dest and name not in vm_key_map:
                vm_key_map[name] = (dest, key)
                new += 1
        print(f"  found {len(vms)} VMs ({new} new)")

    if not vm_key_map:
        print("no VMs found", file=sys.stderr)
        sys.exit(1)

    print("fetching host key from exe.dev ...")
    host_key = fetch_host_key()
    have_known_hosts = False
    if host_key:
        write_known_hosts(vm_key_map, host_key)
        have_known_hosts = True
    else:
        print("  warning: skipping host key pinning", file=sys.stderr)

    config = generate_config(vm_key_map, have_known_hosts)
    with open(CONFIG_FILE, "w") as f:
        f.write(config)
    print(f"wrote {len(vm_key_map)} entries to {CONFIG_FILE}")

    ensure_include()
    print("done")


if __name__ == "__main__":
    main()