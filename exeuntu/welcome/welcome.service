[Unit]
Description=exe.dev box demo/welcome server

[Service]
Type=simple
User=exedev
Group=exedev
WorkingDirectory=/home/exedev/src
ExecStart=/home/exedev/src/welcomed
Restart=always
RestartSec=5
Environment=HOME=/home/exedev
Environment=USER=exedev
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
