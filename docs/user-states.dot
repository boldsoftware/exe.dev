// ==========================================================================
// USER STATE DIAGRAM - exe.dev (Reference Only)
// ==========================================================================
//
// NOTE: The SVG (user-states.svg) is now hand-crafted in Minard style.
// This .dot file documents the state machine but does not generate the SVG.
//
// The visualization uses flowing bands where width represents user volume,
// inspired by Charles Minard's Napoleon's March (1869).
//
// To edit the diagram, modify user-states.svg directly.
//
// ==========================================================================

digraph UserStates {
    // Reference graph showing the state machine logic
    rankdir=LR;
    node [shape=box fontname="Helvetica"];
    edge [fontname="Helvetica" fontsize=9];

    // Entry points
    anonymous [style=bold];

    // SSH registration path
    anonymous -> pending_ssh [label="ssh exe.dev"];
    pending_ssh [label="pending\n(ssh key)"];
    pending_ssh -> registered [label="verify email"];

    // Web registration path (billing-first)
    anonymous -> pending_web [label="/auth"];
    pending_web [label="pending\n(email)"];
    pending_web -> paying [label="stripe checkout"];

    // Note: Box sharing is a per-box capability, not a user state.
    // Invited users go through /auth and billing like anyone else.
    // Their pending shares are resolved upon registration.

    // Billing gate (SSH path only)
    registered -> grandfathered [label="before 2026-01-06"];
    registered -> billing_required [label="after 2026-01-06"];
    registered -> blocked [label="flagged (ipqs)"];

    // Billing resolution
    billing_required -> paying [label="checkout"];
    billing_required -> trial [label="trial code"];
    billing_required -> free [label="invite code"];

    // Trial lifecycle
    trial -> expired [label="time passes"];
    expired -> paying [label="checkout"];

    // Final states
    grandfathered [color=green fontcolor=green];
    paying [style=filled fillcolor=lightgreen];
    free [color=green fontcolor=green];
    trial [color=orange fontcolor=orange];
    expired [style=dashed];
    blocked [style=filled fillcolor=mistyrose color=red fontcolor=red];

    // Capabilities note
    capabilities [shape=note label="All active tiers:\n- Create VMs\n- Add SSH keys\n- Add passkeys\n- Link Discord\n- Access shared boxes"];
    grandfathered -> capabilities [style=dotted arrowhead=none];
    paying -> capabilities [style=dotted arrowhead=none];
    trial -> capabilities [style=dotted arrowhead=none];
    free -> capabilities [style=dotted arrowhead=none];
}
