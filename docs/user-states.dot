digraph UserStates {
    // Tufte principles: maximize data-ink ratio, eliminate chartjunk
    // Every stroke must carry meaning

    graph [
        rankdir=TB
        fontname="Palatino"
        fontsize=10
        bgcolor=white
        margin=0.5
        nodesep=0.4
        ranksep=0.6
        splines=true
    ];

    node [
        fontname="Palatino"
        fontsize=9
        shape=plaintext
        margin=0
    ];

    edge [
        fontname="Palatino"
        fontsize=7
        arrowsize=0.5
        color="#333333"
    ];

    //==========================================================================
    // STATES
    // Shape encodes category:
    //   plaintext = transient/pre-registration
    //   box = registered user state
    //   ellipse = action/capability state
    //==========================================================================

    // Pre-registration (plaintext - they don't exist yet)
    anonymous [label="anonymous"];
    pending_ssh [label="pending\n(ssh key captured)"];
    pending_web [label="pending\n(email entered)"];
    pending_share [label="pending\n(share recipient)"];

    // Billing states (box - core user identity)
    grandfathered [label="grandfathered\n(pre-2026-01-06)" shape=box];
    trial [label="trial\n(expires)" shape=box];
    free [label="free\n(invite code)" shape=box];
    paying [label="paying" shape=box];
    billing_required [label="billing required" shape=box style=dashed];
    trial_expired [label="trial expired" shape=box style=dashed];

    // Capabilities (ellipse - what user can do)
    has_ssh_key [label="has ssh key" shape=ellipse];
    has_passkey [label="has passkey" shape=ellipse];
    has_discord [label="discord linked" shape=ellipse];
    has_vms [label="owns VMs" shape=ellipse];
    has_share_access [label="share access" shape=ellipse];
    support [label="support access" shape=ellipse];

    // Blocked (dashed box - restricted)
    disposable [label="disposable email\n(vm creation blocked)" shape=box style=dashed];

    //==========================================================================
    // REGISTRATION PATHS
    // Solid = primary path, dashed = secondary/rare
    //==========================================================================

    // SSH registration
    anonymous -> pending_ssh [label="ssh connect"];
    pending_ssh -> has_ssh_key [label="verify email"];

    // Web registration (billing-first)
    anonymous -> pending_web [label="/auth"];
    pending_web -> paying [label="stripe checkout"];

    // Share invitation
    anonymous -> pending_share [label="invited" style=dashed];
    pending_share -> has_share_access [label="register"];

    //==========================================================================
    // BILLING TRANSITIONS
    // From ssh registration, billing state depends on creation date
    //==========================================================================

    has_ssh_key -> grandfathered [label="created\nbefore cutoff"];
    has_ssh_key -> billing_required [label="created\nafter cutoff"];

    billing_required -> paying [label="checkout"];
    billing_required -> trial [label="trial code"];
    billing_required -> free [label="free code"];

    trial -> trial_expired [label="time passes"];
    trial_expired -> paying [label="checkout"];

    //==========================================================================
    // CAPABILITY ADDITIONS
    // Users accumulate capabilities; these are additive, not exclusive
    //==========================================================================

    // Any billing-valid user can add auth methods
    {grandfathered paying trial free} -> has_ssh_key [label="add key" style=dashed];
    {grandfathered paying trial free} -> has_passkey [label="register" style=dashed];
    {grandfathered paying trial free} -> has_discord [label="link" style=dashed];

    // VM creation requires valid billing
    {grandfathered paying trial free} -> has_vms [label="create vm"];

    // Support access granted manually
    {grandfathered paying} -> support [label="grant" style=dashed];

    //==========================================================================
    // SHARING
    //==========================================================================

    has_vms -> pending_share [label="invite\nunregistered" style=dashed];
    has_vms -> has_share_access [label="invite\nregistered" style=dashed];

    //==========================================================================
    // RESTRICTIONS
    // Red/dashed = blocking transition
    //==========================================================================

    has_ssh_key -> disposable [label="ipqs flag" color="#990000" style=dashed];

    //==========================================================================
    // LAYOUT HINTS
    //==========================================================================

    {rank=same; anonymous}
    {rank=same; pending_ssh pending_web pending_share}
    {rank=same; has_ssh_key billing_required}
    {rank=same; grandfathered paying trial free trial_expired}
    {rank=same; has_vms has_passkey has_discord has_share_access}
    {rank=same; disposable support}
}
