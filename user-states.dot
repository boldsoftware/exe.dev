digraph UserStates {
    // Graph settings
    rankdir=TB;
    fontname="Helvetica";
    node [fontname="Helvetica", fontsize=11];
    edge [fontname="Helvetica", fontsize=9];
    compound=true;
    splines=polyline;
    nodesep=0.6;
    ranksep=0.8;

    // Color scheme
    // Blue = pre-registration
    // Green = active/positive states
    // Orange = pending/transitional
    // Red = restricted/blocked
    // Purple = special access

    //==========================================================================
    // PRE-REGISTRATION STATES
    //==========================================================================
    subgraph cluster_pre_reg {
        label="Pre-Registration States";
        style=filled;
        fillcolor="#e8f4f8";
        color="#2980b9";

        anonymous [
            label="Anonymous\nVisitor"
            shape=oval
            style=filled
            fillcolor="#bdc3c7"
        ];

        pending_share_recipient [
            label="Pending Share\nRecipient"
            shape=box
            style="filled,rounded"
            fillcolor="#f39c12"
            tooltip="Email has PendingBoxShare but not registered"
        ];

        share_link_visitor [
            label="Share Link\nVisitor"
            shape=box
            style="filled,rounded"
            fillcolor="#9b59b6"
            tooltip="Accessing via BoxShareLink token"
        ];
    }

    //==========================================================================
    // REGISTRATION FLOW STATES
    //==========================================================================
    subgraph cluster_registration {
        label="Registration Flows";
        style=filled;
        fillcolor="#fef9e7";
        color="#f39c12";

        // SSH Registration Flow
        pending_ssh [
            label="Pending SSH\nRegistration"
            shape=box
            style="filled,rounded"
            fillcolor="#f5b041"
            tooltip="SSH key captured, awaiting email verification"
        ];

        email_verification_pending [
            label="Email Verification\nPending"
            shape=box
            style="filled,rounded"
            fillcolor="#f5b041"
            tooltip="Pairing code shown, awaiting email entry"
        ];

        // Web Registration Flow (Billing-First)
        pending_web_reg [
            label="Pending Web\nRegistration"
            shape=box
            style="filled,rounded"
            fillcolor="#f5b041"
            tooltip="Email entered, token issued"
        ];

        stripe_checkout [
            label="Stripe\nCheckout"
            shape=box
            style="filled,rounded"
            fillcolor="#f5b041"
            tooltip="In Stripe payment flow"
        ];
    }

    //==========================================================================
    // REGISTERED USER STATES (by billing)
    //==========================================================================
    subgraph cluster_registered {
        label="Registered Users";
        style=filled;
        fillcolor="#e8f8f5";
        color="#27ae60";

        // Billing states
        grandfathered_user [
            label="Grandfathered\nUser"
            shape=box
            style="filled,rounded"
            fillcolor="#58d68d"
            tooltip="Created before 2026-01-06, no billing required"
        ];

        trial_user [
            label="Trial User"
            shape=box
            style="filled,rounded"
            fillcolor="#82e0aa"
            tooltip="billing_exemption='trial', expires at billing_trial_ends_at"
        ];

        free_user [
            label="Free User"
            shape=box
            style="filled,rounded"
            fillcolor="#58d68d"
            tooltip="billing_exemption='free', no expiration"
        ];

        paying_user [
            label="Paying User"
            shape=box
            style="filled,rounded"
            fillcolor="#2ecc71"
            tooltip="Has active Stripe subscription"
        ];

        billing_required [
            label="Billing\nRequired"
            shape=box
            style="filled,rounded"
            fillcolor="#e74c3c"
            tooltip="New user, must complete billing to use VMs"
        ];
    }

    //==========================================================================
    // AUTH METHOD STATES
    //==========================================================================
    subgraph cluster_auth {
        label="Authentication Methods (additive)";
        style=filled;
        fillcolor="#f4ecf7";
        color="#8e44ad";

        email_only_user [
            label="Email-Only User\n(Login-with-Exe)"
            shape=box
            style="filled,rounded"
            fillcolor="#d2b4de"
            tooltip="created_for_login_with_exe=true, no SSH key"
        ];

        ssh_key_user [
            label="SSH Key\nUser"
            shape=box
            style="filled,rounded"
            fillcolor="#bb8fce"
            tooltip="Has SSH key in ssh_keys table"
        ];

        passkey_user [
            label="Passkey\nEnabled"
            shape=box
            style="filled,rounded"
            fillcolor="#a569bd"
            tooltip="WebAuthn passkey registered"
        ];

        discord_linked [
            label="Discord\nLinked"
            shape=box
            style="filled,rounded"
            fillcolor="#9b59b6"
            tooltip="discord_id populated"
        ];
    }

    //==========================================================================
    // VM OWNERSHIP STATES
    //==========================================================================
    subgraph cluster_vms {
        label="VM Ownership";
        style=filled;
        fillcolor="#eaf2f8";
        color="#3498db";

        no_vms [
            label="No VMs"
            shape=box
            style="filled,rounded"
            fillcolor="#85c1e9"
        ];

        has_vms [
            label="Has VMs"
            shape=box
            style="filled,rounded"
            fillcolor="#3498db"
            fontcolor=white
        ];

        vm_share_owner [
            label="VM Share\nOwner"
            shape=box
            style="filled,rounded"
            fillcolor="#2980b9"
            fontcolor=white
            tooltip="Has shared VMs with others"
        ];
    }

    //==========================================================================
    // SHARE ACCESS STATES
    //==========================================================================
    subgraph cluster_shares {
        label="Share Access";
        style=filled;
        fillcolor="#fdf2e9";
        color="#e67e22";

        no_shares [
            label="No Share\nAccess"
            shape=box
            style="filled,rounded"
            fillcolor="#f5cba7"
        ];

        has_share_access [
            label="Has Share\nAccess"
            shape=box
            style="filled,rounded"
            fillcolor="#e67e22"
            fontcolor=white
            tooltip="Active BoxShare records"
        ];
    }

    //==========================================================================
    // RESTRICTED STATES
    //==========================================================================
    subgraph cluster_restricted {
        label="Restricted States";
        style=filled;
        fillcolor="#fadbd8";
        color="#c0392b";

        disposable_email_user [
            label="Disposable\nEmail User"
            shape=box
            style="filled,rounded"
            fillcolor="#e74c3c"
            fontcolor=white
            tooltip="new_vm_creation_disabled=true"
        ];

        trial_expired [
            label="Trial\nExpired"
            shape=box
            style="filled,rounded"
            fillcolor="#c0392b"
            fontcolor=white
            tooltip="billing_trial_ends_at in past"
        ];
    }

    //==========================================================================
    // SPECIAL ACCESS
    //==========================================================================
    subgraph cluster_special {
        label="Special Access";
        style=filled;
        fillcolor="#ebdef0";
        color="#7d3c98";

        support_user [
            label="Support\nAccess"
            shape=box
            style="filled,rounded"
            fillcolor="#7d3c98"
            fontcolor=white
            tooltip="root_support=true, can access support+vm@exe.cloud"
        ];
    }

    //==========================================================================
    // TRANSITIONS - Registration
    //==========================================================================

    // Anonymous starting points
    anonymous -> pending_ssh [label="SSH connect\nwith new key"];
    anonymous -> pending_web_reg [label="Enter email\nat /auth"];
    anonymous -> share_link_visitor [label="Click share\nlink token"];
    anonymous -> pending_share_recipient [label="Someone shares\nVM to email" style=dashed];

    // SSH Registration flow
    pending_ssh -> email_verification_pending [label="Key stored in\nPendingSSHKey"];
    email_verification_pending -> ssh_key_user [label="Email verified\n+ createUserWithSSHKey"];

    // Web Registration flow (billing-first for new users)
    pending_web_reg -> stripe_checkout [label="Redirect to\n/billing/subscribe"];
    stripe_checkout -> paying_user [label="Checkout success\n+ ActivateAccount"];
    stripe_checkout -> anonymous [label="Checkout cancelled" style=dashed];

    // Share link visitor
    share_link_visitor -> has_share_access [label="Login/register\n+ BoxShare created"];

    // Pending share resolution
    pending_share_recipient -> has_share_access [label="Register with\nsame email\n(resolvePendingShares)"];

    //==========================================================================
    // TRANSITIONS - Billing States
    //==========================================================================

    // Initial billing state based on creation date
    ssh_key_user -> grandfathered_user [label="Created before\n2026-01-06"];
    ssh_key_user -> billing_required [label="Created after\n2026-01-06"];

    // Using invite codes
    billing_required -> trial_user [label="Apply invite code\n(plan_type='trial')"];
    billing_required -> free_user [label="Apply invite code\n(plan_type='free')"];
    billing_required -> paying_user [label="Complete Stripe\ncheckout"];

    // Trial expiration
    trial_user -> trial_expired [label="billing_trial_ends_at\npasses"];
    trial_expired -> paying_user [label="Complete\nbilling"];

    // Email-only user paths
    email_only_user -> billing_required [label="Created after\n2026-01-06"];
    email_only_user -> grandfathered_user [label="Created before\n2026-01-06" style=dashed];

    //==========================================================================
    // TRANSITIONS - Auth Methods (additive)
    //==========================================================================

    // Adding auth methods
    paying_user -> ssh_key_user [label="Add SSH key\n(InsertSSHKey)" dir=both style=dashed];
    paying_user -> passkey_user [label="Register\npasskey" style=dashed];
    paying_user -> discord_linked [label="Link Discord\naccount" style=dashed];

    grandfathered_user -> passkey_user [label="Register\npasskey" style=dashed];
    grandfathered_user -> discord_linked [label="Link Discord" style=dashed];

    //==========================================================================
    // TRANSITIONS - VM Ownership
    //==========================================================================

    // Creating VMs (requires valid billing)
    paying_user -> has_vms [label="Create VM"];
    grandfathered_user -> has_vms [label="Create VM"];
    trial_user -> has_vms [label="Create VM"];
    free_user -> has_vms [label="Create VM"];

    // Can't create VMs
    billing_required -> no_vms [label="" style=invis];
    disposable_email_user -> no_vms [label="Blocked from\nVM creation" style=dashed color=red];

    // Sharing VMs
    has_vms -> vm_share_owner [label="Share VM\nwith email/link"];
    vm_share_owner -> pending_share_recipient [label="Invitee not\nregistered" style=dashed];

    // Deleting VMs
    has_vms -> no_vms [label="Delete all VMs" style=dashed];

    //==========================================================================
    // TRANSITIONS - Special States
    //==========================================================================

    // Disposable email detection
    ssh_key_user -> disposable_email_user [label="IPQS detects\ndisposable email" color=red];
    paying_user -> disposable_email_user [label="IPQS detects\ndisposable email" color=red style=dashed];

    // Support access (granted manually)
    paying_user -> support_user [label="Grant\nroot_support" style=dashed];
    grandfathered_user -> support_user [label="Grant\nroot_support" style=dashed];

    //==========================================================================
    // LEGEND
    //==========================================================================
    subgraph cluster_legend {
        label="Legend";
        style=filled;
        fillcolor="#fafafa";
        color="#95a5a6";
        fontsize=10;

        leg_solid [label="Solid line =\nPrimary transition" shape=plaintext fontsize=9];
        leg_dashed [label="Dashed line =\nSecondary/rare" shape=plaintext fontsize=9];
        leg_red [label="Red line =\nBlocking/restriction" shape=plaintext fontsize=9];
    }

    //==========================================================================
    // QUESTIONS ANSWERED IN DIAGRAM
    //==========================================================================
    // Invisible node for documentation
    questions [
        shape=note
        style=filled
        fillcolor="#fffacd"
        label=<<table border="0" cellborder="0" cellspacing="0">
        <tr><td align="left"><b>Key Questions Answered:</b></td></tr>
        <tr><td align="left">1. Not-yet-exe users = pending_share_recipient (has email share)</td></tr>
        <tr><td align="left">   or pending_ssh/pending_web_reg (mid-registration)</td></tr>
        <tr><td align="left">2. They become full users via email verification + billing</td></tr>
        <tr><td align="left">3. Pending shares auto-resolve via resolvePendingShares()</td></tr>
        <tr><td align="left">4. Share links work for anonymous (visitor state)</td></tr>
        <tr><td align="left">5. Billing required only after 2026-01-06 (grandfathering)</td></tr>
        <tr><td align="left">6. Trial/free exemptions skip billing requirement</td></tr>
        <tr><td align="left">7. Disposable email users blocked from VM creation</td></tr>
        <tr><td align="left">8. Auth methods are additive (SSH + passkey + Discord)</td></tr>
        </table>>
    ];
}
