[Unit]
Description=SSH Piper Proxy Server
Documentation=https://github.com/tg123/sshpiper
After=network.target exed.service
Requires=exed.service
Wants=network-online.target

[Service]
Type=exec
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu
ExecStart=/bin/bash -lc 'set -euo pipefail; PRIVATE_KEY=$(sqlite3 /home/ubuntu/exe.db "SELECT private_key FROM ssh_host_key WHERE id = 1;"); set -- /home/ubuntu/sshpiperd.latest --log-level=INFO --port=22 --drop-hostkeys-message --server-key-data="$(echo "$PRIVATE_KEY" | base64 -w 0)" grpc --endpoint=localhost:2224 --insecure; if command -v tailscale >/dev/null 2>&1; then TS_IP=$(tailscale ip -4 2>/dev/null | sed "/^[[:space:]]*$/d" | head -n1); if [ -z "$TS_IP" ]; then echo "tailscale IPv4 address required"; exit 1; fi; set -- "$@" -- /home/ubuntu/metrics.latest --collect-pipe-create-errors --collect-upstream-auth-failures --address "$TS_IP" --port 30303; fi; exec "$@"'
Restart=always
RestartSec=5
TimeoutStartSec=30
TimeoutStopSec=30
KillMode=mixed
KillSignal=SIGTERM

# Security settings
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=false
ReadWritePaths=/home/ubuntu

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=sshpiper

# Allow binding to privileged ports
AmbientCapabilities=CAP_NET_BIND_SERVICE
CapabilityBoundingSet=CAP_NET_BIND_SERVICE

[Install]
WantedBy=multi-user.target
