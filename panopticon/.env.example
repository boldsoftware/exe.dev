# GitHub personal access token (classic or fine-grained)
# Needs: repo read access (issues, comments)
EXE_GITHUB_TOKEN=ghp_...

# Discord bot token
# Needs: guilds, guild messages intents
EXE_DISCORD_BOT_TOKEN=...

# Discord guild (server) ID (optional — auto-detects if bot has guilds scope)
# EXE_DISCORD_GUILD_ID=...

# Anthropic API key (used by newsletter RLM)
ANTHROPIC_API_KEY=sk-ant-...

# Missive API key (optional — enables shared email/support queue source)
# Generate from Missive preferences > API tab. Requires Productive plan.
# EXE_MISSIVE_API_KEY=missive_pat-...
