#!/bin/bash
# Push a commit to edric for e1e tests. Defaults to HEAD.
#
# This only tests committed code. If you're changing e1ed infra itself
# (cmd/e1ed, cmd/e1ed-hook, exelet, execore, etc.), you need to redeploy
# first: ./ops/deploy/deploy-e1ed.sh and/or ./ops/deploy/deploy-e1ed-hook.sh
#
# Usage:
#   bin/e1e              # test HEAD
#   bin/e1e my-branch    # test tip of my-branch
#   bin/e1e abc123       # test a specific commit
set -euo pipefail

ref="${1:-HEAD}"
commit=$(git rev-parse "$ref")
# Create a unique commit (same tree, new hash) so re-pushing the same ref
# isn't a no-op.
junk=$(git commit-tree "$commit^{tree}" -p "$commit" -m "e1e $(date +%s)")
git push --force -q root@edric:/data/e1ed/push.git "$junk":refs/e1e/test
