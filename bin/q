#!/usr/bin/env python3
"""q — push to a CI queue branch and wait for the run to finish.

Pushes the given ref (default HEAD) to a queue branch on origin,
then polls CI until the run completes.

GitHub Actions: pushes to queue-main-* and polls via `gh`.
Buildkite (--kite): pushes to kite-queue-* and polls via Buildkite API.
Buildkite (--dry-run): pushes to kite-test-* (tests only, no merge).

Buildkite API access: set BUILDKITE_API_PROXY (e.g. https://buildkite.int.exe.xyz/)
or BUILDKITE_API_TOKEN for direct access.
"""

import argparse
import json
import os
import re
import subprocess
import sys
import time
import urllib.error
import urllib.parse
import urllib.request


def run(cmd, *, check=True, capture=True, quiet=False):
    """Run a command, return stdout (stripped). Prints stderr on failure."""
    r = subprocess.run(
        cmd,
        capture_output=capture,
        text=True,
    )
    if check and r.returncode != 0:
        if capture and r.stderr:
            sys.stderr.write(r.stderr)
        raise SystemExit(1)
    return r.stdout.strip() if capture else ""


def git(*args, **kwargs):
    return run(["git", *args], **kwargs)


def gh(*args, **kwargs):
    return run(["gh", *args], **kwargs)


def slugify(text):
    """Convert text to a branch-name-safe slug."""
    s = text.lower()
    s = re.sub(r"[^a-z0-9._-]+", "_", s)
    s = s.strip("_.-")
    return s


def gh_has_actions_access():
    """Check whether gh can access the Actions API."""
    r = subprocess.run(
        ["gh", "run", "list", "--limit", "1"],
        capture_output=True, text=True,
    )
    return r.returncode == 0


def find_run(branch, commit, timeout=120, interval=2):
    """Poll until a workflow run appears for the given branch+commit."""
    for _ in range(timeout // interval):
        try:
            out = gh(
                "run", "list",
                "--branch", branch,
                "--limit", "10",
                "--json", "headSha,databaseId",
                check=False,
            )
            if not out:
                time.sleep(interval)
                continue
            for r in json.loads(out):
                if r.get("headSha") == commit:
                    return r["databaseId"]
        except (json.JSONDecodeError, KeyError):
            pass
        time.sleep(interval)
    return None


BUILDKITE_ORG = "bold-software"
BUILDKITE_PIPELINE = "exe-kite-queue"
BUILDKITE_TERMINAL_STATES = {"passed", "failed", "blocked", "canceled", "skipped", "not_run"}


def bk_api(path):
    """Call the Buildkite REST API. Returns parsed JSON, or None on error.

    Checks BUILDKITE_API_PROXY first (e.g. https://buildkite.int.exe.xyz/),
    which injects auth server-side and needs no token. Falls back to
    BUILDKITE_API_TOKEN for direct api.buildkite.com access.
    """
    proxy = os.environ.get("BUILDKITE_API_PROXY", "").rstrip("/")
    token = os.environ.get("BUILDKITE_API_TOKEN", "")
    headers = {"Accept": "application/json"}
    if proxy:
        url = f"{proxy}/v2/organizations/{BUILDKITE_ORG}/pipelines/{BUILDKITE_PIPELINE}/{path}"
    elif token:
        url = f"https://api.buildkite.com/v2/organizations/{BUILDKITE_ORG}/pipelines/{BUILDKITE_PIPELINE}/{path}"
        headers["Authorization"] = f"Bearer {token}"
    else:
        return None
    req = urllib.request.Request(url, headers=headers)
    try:
        with urllib.request.urlopen(req, timeout=10) as resp:
            return json.loads(resp.read())
    except (urllib.error.URLError, json.JSONDecodeError, OSError):
        return None


def find_bk_build(branch, commit, timeout=120, interval=2):
    """Poll until a Buildkite build appears for the given branch+commit."""
    branch_enc = urllib.parse.quote(branch, safe="")
    for _ in range(timeout // interval):
        data = bk_api(f"builds?branch={branch_enc}&commit={commit}&per_page=1")
        if data and len(data) > 0:
            return data[0]
        time.sleep(interval)
    return None


def poll_bk_build(build_number, interval=10):
    """Poll a Buildkite build until completion. Returns (state, elapsed_secs, build_data)."""
    t0 = time.monotonic()
    while True:
        data = bk_api(f"builds/{build_number}")
        state = data.get("state", "") if data else ""
        elapsed = int(time.monotonic() - t0)
        if state in BUILDKITE_TERMINAL_STATES:
            sys.stderr.write("\n")
            return state, elapsed, data or {}
        m, s = divmod(elapsed, 60)
        sys.stderr.write(f"\rq: running [{m}m{s:02d}s]")
        sys.stderr.flush()
        time.sleep(interval)


def _strip_bk_ansi(text):
    """Remove Buildkite timestamps and ANSI escape codes from log text."""
    # OSC sequences: \x1b_bk;t=NNN\x07  (Buildkite timestamps)
    text = re.sub(r'\x1b_bk;t=\d+\x07', '', text)
    # Fallback for plain _bk;t= (seen in .txt endpoint)
    text = re.sub(r'_bk;t=\d+', '', text)
    # SGR sequences: \x1b[...m  (colors)
    text = re.sub(r'\x1b\[[0-9;]*m', '', text)
    # Any remaining OSC/escape sequences
    text = re.sub(r'\x1b\x07', '', text)
    return text


# Lines that are Buildkite framing, not useful error context.
_BK_NOISE_PREFIXES = ('^^^ ', '~~~ ', 'user command error:')


def _extract_errors(log_content, max_lines=30):
    """Extract error/failure lines from a Buildkite job log."""
    log_content = _strip_bk_ansi(log_content)
    lines = log_content.splitlines()

    error_lines = []
    for i, line in enumerate(lines):
        stripped = line.strip()
        if not stripped or stripped.startswith(_BK_NOISE_PREFIXES):
            continue
        # Match Go test failures, FAIL lines, error messages, panics
        if any(pat in stripped for pat in [
            'FAIL\t', '--- FAIL', 'FAILED',
            'panic:', 'error:',
            'not usable:', 'no such file',
            'DONE ', '=== FAIL',
        ]):
            # Grab some context around the error
            start = max(0, i - 2)
            for ctx_line in lines[start:i+1]:
                ctx = ctx_line.strip()
                if ctx and ctx not in error_lines \
                        and not ctx.startswith(_BK_NOISE_PREFIXES):
                    error_lines.append(ctx)

    if not error_lines:
        # Fallback: last N non-empty lines
        tail = [l.strip() for l in lines[-max_lines:] if l.strip()
                and not l.strip().startswith(_BK_NOISE_PREFIXES)]
        return tail[-max_lines:]

    return error_lines[-max_lines:]


def print_bk_failures(build_data):
    """Fetch and display failure details from a Buildkite build."""
    jobs = build_data.get("jobs", [])
    failed_jobs = [j for j in jobs if j.get("state") in ("failed",)]
    if not failed_jobs:
        return

    build_number = build_data.get("number", "?")
    for job in failed_jobs:
        name = _strip_bk_ansi(job.get("name", "unknown"))
        web_url = job.get("web_url", "")
        job_id = job.get("id", "")

        print(f"\nq: \u2500\u2500 {name} \u2500\u2500", file=sys.stderr)
        if web_url:
            print(f"q: {web_url}", file=sys.stderr)

        # Fetch the job log
        if not job_id:
            continue
        log_data = bk_api(f"builds/{build_number}/jobs/{job_id}/log")
        if not log_data or not log_data.get("content"):
            print("q: (could not fetch log)", file=sys.stderr)
            continue

        error_lines = _extract_errors(log_data["content"])
        if error_lines:
            print("", file=sys.stderr)
            for line in error_lines:
                print(f"  {line}", file=sys.stderr)
            print("", file=sys.stderr)


def watch_origin_main(ref, timeout=300, interval=15):
    """Watch origin/main for a commit with the same subject as ref. Returns True if found."""
    subject = git("--no-pager", "log", "--format=%s", "-n", "1", ref)
    print(f"q: no Actions API access, watching origin/main for: {subject}", file=sys.stderr)

    t0 = time.monotonic()
    while True:
        elapsed = int(time.monotonic() - t0)
        m, s = divmod(elapsed, 60)

        if elapsed >= timeout:
            sys.stderr.write("\n")
            print(f"q: not merged after {m}m{s}s", file=sys.stderr)
            return False

        git("fetch", "origin", "main", "--quiet", check=False)
        subjects = git("--no-pager", "log", "origin/main", "--format=%s", "-20").splitlines()
        if subject in subjects:
            sys.stderr.write("\n")
            print(f"q: merged to main [{m}m{s}s]", file=sys.stderr)
            return True

        sys.stderr.write(f"\rq: waiting for merge [{m}m{s:02d}s]")
        sys.stderr.flush()
        time.sleep(interval)


def poll_run(run_id, interval=10):
    """Poll a run until completion. Returns (conclusion, elapsed_secs)."""
    t0 = time.monotonic()
    while True:
        out = gh("run", "view", str(run_id), "--json", "status,conclusion", check=False)
        try:
            data = json.loads(out)
        except (json.JSONDecodeError, TypeError):
            data = {}
        status = data.get("status", "")
        conclusion = data.get("conclusion", "")
        elapsed = int(time.monotonic() - t0)
        if status == "completed":
            sys.stderr.write("\n")
            return conclusion, elapsed
        m, s = divmod(elapsed, 60)
        sys.stderr.write(f"\rq: running [{m}m{s:02d}s]")
        sys.stderr.flush()
        time.sleep(interval)


def can_rebase_cleanly(ref, onto="origin/main"):
    """Simulate rebasing ref onto 'onto' using git merge-tree --write-tree (Git 2.38+).
    Returns True if all commits can be cherry-picked without conflicts."""
    commits = git("rev-list", "--reverse", f"{onto}..{ref}").splitlines()
    if not commits:
        return True

    current_base = git("rev-parse", onto)

    for commit in commits:
        parent = git("rev-parse", f"{commit}^")
        r = subprocess.run(
            ["git", "merge-tree", "--write-tree", "--merge-base", parent, current_base, commit],
            capture_output=True, text=True,
        )
        if r.returncode != 0:
            return False

        result_tree = r.stdout.strip().splitlines()[0]

        # Skip commits that would be empty after rebase (already applied)
        base_tree = git("rev-parse", f"{current_base}^{{tree}}")
        if result_tree == base_tree:
            continue

        # Chain: create temp commit as base for next iteration
        current_base = git("commit-tree", result_tree, "-p", current_base, "-m", "tmp")

    return True


def run_generate():
    """Run go generate and fail if it produces uncommitted changes."""
    print("q: running go generate...", file=sys.stderr)
    run(["go", "generate", "./..."], capture=False)
    if subprocess.run(["git", "diff", "--quiet"], capture_output=True).returncode != 0:
        print("q: go generate produced changes; commit them first", file=sys.stderr)
        git("--no-pager", "diff", "--stat", capture=False)
        raise SystemExit(1)
    print("q: go generate clean", file=sys.stderr)


def run_linters():
    """Run custom linters (go vet + exelint). Raises SystemExit on failure."""
    print("q: running linters...", file=sys.stderr)
    git_root = git("rev-parse", "--show-toplevel")
    exelint = os.path.join(git_root, "cmd", "exelint")

    run(["go", "vet", "./..."], capture=False)
    run(["go", "build", "-o", "/tmp/exelint", f"./{os.path.relpath(exelint, git_root)}"], capture=False)
    run(["go", "vet", "-vettool=/tmp/exelint", "./..."], capture=False)
    print("q: linters passed", file=sys.stderr)


def run_formatters(ref):
    """Run formatters if available and ref is HEAD. Returns True if commit was amended."""
    if ref != "HEAD":
        return False
    git_root = git("rev-parse", "--show-toplevel")
    formatter = os.path.join(git_root, "bin", "run_formatters.sh")
    if not os.path.isfile(formatter) or not os.access(formatter, os.X_OK):
        return False

    # Check for staged or modified files
    dirty_unstaged = subprocess.run(
        ["git", "diff", "--quiet"], capture_output=True
    ).returncode != 0
    dirty_staged = subprocess.run(
        ["git", "diff", "--cached", "--quiet"], capture_output=True
    ).returncode != 0
    if dirty_unstaged or dirty_staged:
        print("q: worktree has staged or modified files; commit or stash first", file=sys.stderr)
        raise SystemExit(1)

    print("q: running formatters...", file=sys.stderr)
    subprocess.run([formatter], check=True)

    # If formatters changed files that are in HEAD, amend
    if subprocess.run(["git", "diff", "--quiet"], capture_output=True).returncode != 0:
        print("q: formatters produced changes, amending commit...", file=sys.stderr)
        # Only add files that were both changed by formatters AND in the HEAD commit
        changed = git("diff", "--name-only").splitlines()
        in_head = git("diff-tree", "--no-commit-id", "--name-only", "-r", "HEAD").splitlines()
        to_add = [f for f in changed if f in set(in_head)]
        if to_add:
            git("add", *to_add)
            git("commit", "--amend", "--no-edit")
            return True
    return False


# Per-user default flags, keyed by git config user.email.
# Add your email and preferred defaults here.
USER_DEFAULTS = {
    "josharian@gmail.com":       ["--no-format"],
    "philip@bold.dev":           ["--slug"],
    "philip.zeyliger@gmail.com": ["--slug"],
}


def get_user_email():
    """Get git config user.email, or empty string on failure."""
    r = subprocess.run(
        ["git", "config", "user.email"],
        capture_output=True, text=True,
    )
    return r.stdout.strip() if r.returncode == 0 else ""


def run_post_hook(command):
    """Run a shell command if non-empty. Failures are reported but don't change the exit code."""
    if not command:
        return
    r = subprocess.run(command, shell=True)
    if r.returncode != 0:
        print(f"q: post hook {command!r} exited {r.returncode}", file=sys.stderr)


def main():
    email = get_user_email()
    user_defaults = USER_DEFAULTS.get(email, [])

    p = argparse.ArgumentParser(description=__doc__)
    p.add_argument("ref", nargs="?", default="HEAD", help="ref to push (default: HEAD)")
    p.add_argument("--no-generate", "-G", action="store_true",
                    help="skip running go generate")
    p.add_argument("--no-format", "-F", action="store_true",
                    help="skip running formatters")
    p.add_argument("--no-lint", "-L", action="store_true",
                    help="skip running linters (go vet + exelint)")
    p.add_argument("--no-check", "-C", action="store_true",
                    help="skip fast-forward dry-run check against origin/main")
    p.add_argument("--slug", "-s", action="store_true", default=None,
                    help="name queue branch from commit message instead of branch name")
    p.add_argument("--no-slug", "-S", action="store_true",
                    help="name queue branch from git branch name")
    p.add_argument("--rebase", "-R", action="store_true", default=True,
                    help="auto-rebase onto origin/main if needed (only if conflict-free)")
    p.add_argument("--no-rebase", action="store_true",
                    help="don't auto-rebase; fail if not fast-forwardable")
    p.add_argument("--kite", "-k", action="store_true",
                    help="use Buildkite queue (push to kite-queue-* branch)")
    p.add_argument("--dry-run", "-n", action="store_true",
                    help="use Buildkite test-only (push to kite-test-* branch, no merge)")
    p.add_argument("--no-fetch", action="store_true",
                    help="skip fetching origin/main on success")
    p.add_argument("--post-success", default="",
                    help="shell command to run after successful CI (e.g. 'say passed')")
    p.add_argument("--post-failure", default="",
                    help="shell command to run after failed CI (e.g. 'say failed')")

    # Parse user defaults first, then real args on top.
    args = p.parse_args(user_defaults)
    args = p.parse_args(namespace=args)

    # Resolve --slug/--no-slug: explicit --no-slug wins, then --slug, then False.
    if args.no_slug:
        args.slug = False
    elif args.slug is None:
        args.slug = False
    del args.no_slug

    if args.no_rebase:
        args.rebase = False
    del args.no_rebase

    ref = args.ref

    # Always run from repo root so linters/formatters/go vet work from subdirs.
    git_root = git("rev-parse", "--show-toplevel")
    os.chdir(git_root)

    # --- Validation ---
    branch = git("rev-parse", "--abbrev-ref", "HEAD")
    if branch == "HEAD":
        print("q: detached HEAD; check out a branch first", file=sys.stderr)
        raise SystemExit(1)

    for tool in ["gh"]:
        if subprocess.run(["which", tool], capture_output=True).returncode != 0:
            print(f"q: {tool} not found", file=sys.stderr)
            raise SystemExit(1)

    # --- Fetch + check (before formatters so we fail fast on rebase needed) ---
    if not args.no_check:
        print("q: fetching origin/main...", file=sys.stderr)
        git("fetch", "origin", "main")
        dry = subprocess.run(
            ["git", "push", "--dry-run", "origin", f"{ref}:main"],
            capture_output=True,
        )
        if dry.returncode != 0:
            if not args.rebase:
                print(f"q: {ref} cannot fast-forward to origin/main; rebase first", file=sys.stderr)
                raise SystemExit(1)
            if ref != "HEAD":
                print(f"q: --rebase only works with HEAD (got {ref})", file=sys.stderr)
                raise SystemExit(1)
            print("q: needs rebase, simulating...", file=sys.stderr)
            if not can_rebase_cleanly(ref):
                print("q: rebase would conflict; resolve manually", file=sys.stderr)
                raise SystemExit(1)
            print("q: rebase looks clean, rebasing...", file=sys.stderr)
            git("rebase", "origin/main")

    # --- Generate ---
    if not args.no_generate:
        run_generate()

    # --- Formatters ---
    if not args.no_format:
        run_formatters(ref)

    # --- Linters ---
    if not args.no_lint:
        run_linters()

    # --- Resolve commit (after possible formatter amend) ---
    commit = git("rev-parse", ref)
    short = commit[:7]

    # --- Show what's being pushed ---
    log_out = git("--no-pager", "log", "--oneline", f"origin/main..{ref}")
    stat_out = git("--no-pager", "diff", "--stat", f"origin/main..{ref}")
    if log_out:
        print(f"\n{log_out}\n", file=sys.stderr)
    if stat_out:
        print(stat_out, file=sys.stderr)

    # --- Queue branch name ---
    if args.dry_run:
        prefix = "kite-test"
    elif args.kite:
        prefix = "kite-queue"
    else:
        prefix = "queue-main"

    user = os.environ.get("USER", "unknown")
    if args.slug:
        subject = git("--no-pager", "log", "--format=%s", "-n", "1", ref)
        queue_branch = f"{prefix}-{user}-{slugify(subject)}"
    else:
        queue_branch = f"{prefix}-{user}-{branch}"

    # --- Push ---
    print(f"\nq: pushing {short} to {queue_branch}", file=sys.stderr)
    git("push", "-f", "origin", f"{commit}:refs/heads/{queue_branch}")

    # --- Kite: Buildkite monitoring ---
    if args.kite or args.dry_run:
        has_bk_api = os.environ.get("BUILDKITE_API_PROXY", "") or os.environ.get("BUILDKITE_API_TOKEN", "")
        if not has_bk_api:
            print("q: set BUILDKITE_API_PROXY or BUILDKITE_API_TOKEN to monitor build progress", file=sys.stderr)
            if args.dry_run:
                return
            # Fall back to watching origin/main for merge
            if not watch_origin_main(ref, timeout=300):
                run_post_hook(args.post_failure)
                raise SystemExit(1)
            run_post_hook(args.post_success)
            if not args.no_fetch:
                git("fetch", "origin", "main", "--quiet", check=False)
            return

        print("q: waiting for Buildkite build...", file=sys.stderr)
        build = find_bk_build(queue_branch, commit)
        if not build:
            print(f"q: no Buildkite build found for {short} after 120s", file=sys.stderr)
            raise SystemExit(1)

        web_url = build.get("web_url", "")
        if web_url:
            print(f"q: {web_url}", file=sys.stderr)

        state, elapsed, build_data = poll_bk_build(build["number"])
        m, s = divmod(elapsed, 60)

        if state == "passed":
            print(f"q: passed [{m}m{s}s]", file=sys.stderr)
            if not args.dry_run and not args.no_fetch:
                git("fetch", "origin", "main", "--quiet", check=False)
            run_post_hook(args.post_success)
        else:
            final_url = build_data.get("web_url", web_url)
            msg = f"q: FAILED ({state}) [{m}m{s}s]"
            if final_url:
                msg += f" {final_url}"
            print(msg, file=sys.stderr)
            print_bk_failures(build_data)
            run_post_hook(args.post_failure)
            raise SystemExit(1)
        return

    # --- Find and monitor the CI run ---
    if not gh_has_actions_access():
        # Fallback: watch origin/main for the merge
        if not watch_origin_main(ref, timeout=300):
            run_post_hook(args.post_failure)
            raise SystemExit(1)
        run_post_hook(args.post_success)
        return

    print("q: waiting for run...", file=sys.stderr)
    run_id = find_run(queue_branch, commit)
    if not run_id:
        print(f"q: no run found for {short} after 120s", file=sys.stderr)
        raise SystemExit(1)

    # Show run URL
    try:
        repo = gh("repo", "view", "--json", "nameWithOwner", "--jq", ".nameWithOwner")
        url = f"https://github.com/{repo}/actions/runs/{run_id}"
        print(f"q: {url}", file=sys.stderr)
    except SystemExit:
        url = None

    # --- Poll ---
    conclusion, elapsed = poll_run(run_id)
    m, s = divmod(elapsed, 60)

    if conclusion == "success":
        print(f"q: passed [{m}m{s}s]", file=sys.stderr)
        if not args.no_fetch:
            git("fetch", "origin", "main", "--quiet", check=False)
        run_post_hook(args.post_success)
    else:
        if url:
            print(f"q: FAILED [{m}m{s}s] {url}", file=sys.stderr)
        else:
            print(f"q: FAILED [{m}m{s}s]", file=sys.stderr)
        run_post_hook(args.post_failure)
        raise SystemExit(1)


if __name__ == "__main__":
    main()
