#!/usr/bin/env python3
"""Extract a Go function/method to a new file using gopls."""

import os
import subprocess
import sys


def run(cmd, **kwargs):
    return subprocess.run(cmd, capture_output=True, text=True, **kwargs)


def find_symbol(filename, funcname):
    """Use gopls symbols to find a function/method by name.

    Returns (name_line, kind) or exits on failure.
    gopls symbols output format:
        Loop Function 31:6-31:10
        (*Manager).Subscribe Method 189:19-189:28
    """
    r = run(["gopls", "symbols", filename])
    for line in r.stdout.splitlines():
        parts = line.split()
        if len(parts) < 3:
            continue
        sym, kind, span = parts[0], parts[1], parts[2]
        # Strip receiver prefix: (*Manager).Subscribe -> Subscribe
        bare = sym.rsplit(".", 1)[-1]
        if bare == funcname and kind in ("Function", "Method"):
            name_line = int(span.split(":")[0])
            return name_line

    print(f"error: function {funcname} not found in {filename}", file=sys.stderr)
    # Show what's available.
    for line in r.stdout.splitlines():
        parts = line.split()
        if len(parts) >= 2 and parts[1] in ("Function", "Method"):
            print(f"  {line}", file=sys.stderr)
    sys.exit(1)


def find_range(filename, name_line):
    """Walk the source to find the full function extent (with doc comments)."""
    with open(filename) as f:
        lines = f.readlines()

    # Walk backwards from name_line to include doc comments.
    start = name_line
    for i in range(name_line - 2, -1, -1):  # name_line is 1-indexed
        if lines[i].startswith("//"):
            start = i + 1  # convert to 1-indexed
        else:
            break

    # TODO: replace brace counting with go/ast (gopls symbols only returns the name range)
    # Walk forward counting braces to find the closing }.
    depth = 0
    started = False
    for i in range(name_line - 1, len(lines)):  # 0-indexed
        for ch in lines[i]:
            if ch == "{":
                depth += 1
                started = True
            elif ch == "}":
                depth -= 1
        if started and depth == 0:
            end = i + 1  # 1-indexed
            return start, end

    print(f"error: could not find end of function (unbalanced braces?)", file=sys.stderr)
    sys.exit(1)


def extract(filename, start, end, dest):
    """Run gopls codeaction to extract, then rename if dest is specified."""
    span = f"{filename}:{start}:1-{end}:2"
    print(f"{span}", file=sys.stderr)

    cmd = ["gopls", "codeaction", "-kind=refactor.extract.toNewFile",
           "-exec", "-write", "-list", span]
    r = run(cmd)
    if r.returncode != 0:
        print(r.stderr, file=sys.stderr, end="")
        sys.exit(r.returncode)

    # -list prints the filenames that were modified/created.
    # The new file is the one that isn't our source file.
    source = os.path.abspath(filename)
    created = None
    for line in r.stdout.splitlines():
        path = line.strip()
        if path and os.path.abspath(path) != source:
            created = path

    if dest and created:
        dest_path = os.path.join(os.path.dirname(created), dest)
        os.rename(created, dest_path)
        created = dest_path

    if created:
        print(created, file=sys.stderr)


def main():
    if len(sys.argv) < 3 or len(sys.argv) > 4:
        print("usage: extract-go-function <file> <func> [newfile]", file=sys.stderr)
        sys.exit(1)

    filename = sys.argv[1]
    funcname = sys.argv[2]
    dest = sys.argv[3] if len(sys.argv) == 4 else None

    name_line = find_symbol(filename, funcname)
    start, end = find_range(filename, name_line)
    extract(filename, start, end, dest)


if __name__ == "__main__":
    main()
